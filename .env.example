DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bash_m_money
SESSION_SECRET=replace-with-a-long-random-secret
PORT=5000
LOG_LEVEL=info

# Frontend dev server defaults to 5173 and proxies /api to this URL.
VITE_API_PROXY_TARGET=http://localhost:5000

# Set this when building the APK for a hosted backend, for example Render.
# Do not include a trailing slash.
VITE_API_BASE_URL=https://bash-m-money-api.onrender.com
BASE_PATH=/

# Optional notification providers.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
